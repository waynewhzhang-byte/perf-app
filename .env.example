# PostgreSQL
DATABASE_URL="postgresql://perf:perf@localhost:5432/perf?schema=public"

# JWT 会话签名密钥 (openssl rand -hex 32)
JWT_SECRET="change-me-to-a-32byte-hex-string"

# 通知渠道密钥加密（AES-256-GCM）(openssl rand -hex 32)
NOTIFY_SECRET_KEY="change-me-to-a-32byte-hex-string"

# MinIO（SDK 使用 API 端口 9000；Web 控制台端口与 API 无关）
# 本机 minio server：RootUser/RootPass 默认 minioadmin / minioadmin
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=perf-attachments

# 应用 baseUrl（用于通知中插入链接）
APP_BASE_URL=http://localhost:3000

# 附件上传（可选，默认 10MB / 每项 20 个）
# UPLOAD_MAX_FILE_SIZE_MB=10
# UPLOAD_MAX_FILES_PER_ITEM=20
